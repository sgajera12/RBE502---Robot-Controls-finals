%% sim_trajectory.m - Trajectory Tracking: Compare CT, Robust, Adaptive
% Uses forward Euler integration (not RK4) to match real-robot behavior.
% Copied from working sim_regulation.m, only q_d changes over time.
clc; clear all; close all;
addpath("generated_dynamics");

%% Load nominal parameters
R = load('Identification/identification_result.mat');
p_nom = [R.p(1:6); ...
         R.x_opt_vec(1); R.x_opt_vec(2); R.x_opt_vec(3); R.x_opt_vec(4); ...
         R.x_opt_vec(5); R.x_opt_vec(6); R.x_opt_vec(7); ...
         R.x_opt_vec(8); R.x_opt_vec(9); R.x_opt_vec(10); ...
         R.x_opt_vec(11); R.x_opt_vec(12); R.x_opt_vec(13); ...
         R.x_opt_vec(14); R.x_opt_vec(15); R.x_opt_vec(16); ...
         R.id_info.g];

%% True plant parameters
alpha = 1.3;
p_true = p_nom;
p_true(7:22) = p_nom(7:22) * alpha;

%% Known geometric parameters
p_geom = [p_nom(1:6); p_nom(23)];

%% Timing
Ts = 0.01;
tf = 60;
t = 0:Ts:tf;
N = length(t);

%% Desired trajectory - slow sinusoidal
q_center = [0.30; -0.20; 0.20; 0.10];
A_amp = [0.15; 0.10; 0.08; 0.05];
omega = [1.0; 0.8; 1.2; 0.6];

q_d = zeros(4, N);
q_dot_d_all = zeros(4, N);
q_ddot_d_all = zeros(4, N);
for k = 1:N
    q_d(:,k)          = q_center + A_amp .* sin(omega * t(k));
    q_dot_d_all(:,k)  = A_amp .* omega .* cos(omega * t(k));
    q_ddot_d_all(:,k) = -A_amp .* (omega.^2) .* sin(omega * t(k));
end

%% Initial conditions
q0 = q_d(:,1);
q_dot0 = q_dot_d_all(:,1);

%% Controller gains (SAME as regulation)
Kp = diag([1 5 4 1]);
Kv = diag([0.5 0.5 0.2 0.008]);
M = M_fun(q0, p_nom);

%% Lyapunov equation (SAME as regulation)
n = 4;
A_err = [zeros(n) eye(n); -pinv(M)*Kp -pinv(M)*Kv];
Q_lyap = eye(2*n);
P = lyap(A_err', Q_lyap);

%% Robust parameters (SAME)
rho = 0.8;

%% Adaptive parameters (SAME)
n_params = 16;
pi_hat_0 = p_nom(7:22);
R_gain = 1e3 * eye(n_params);
R_inv = inv(R_gain);

%% ===================== RUN 1: Computed Torque =====================
fprintf('Running Computed Torque...\n');
q_ct = zeros(4, N+1); q_dot_ct = zeros(4, N+1); tau_ct = zeros(4, N);
q_ct(:,1) = q0; q_dot_ct(:,1) = q_dot0;

for k = 1:N
    q_now = q_ct(:,k);
    q_dot_now = q_dot_ct(:,k);
t   au_ct(:,k) = inverse_controller(q_now, q_dot_now, ...
                                     q_d(:,k), q_dot_d_all(:,k), q_ddot_d_all(:,k), Kp, Kv, p_nom);
    % forward Euler: compute acceleration, then integrate
    M_plant = M_fun(q_now, p_true);
    C_plant = C_fun(q_now, q_dot_now, p_true);
    G_plant = G_fun(q_now, p_true);
    q_ddot = M_plant \ (tau_ct(:,k) - C_plant * q_dot_now - G_plant);

    % check for blow-up
    if any(~isfinite(q_ddot))
        fprintf('CT BLEW UP at k=%d, t=%.2f\n', k, t(k));
        q_ct = q_ct(:,1:k); q_dot_ct = q_dot_ct(:,1:k);
        tau_ct = tau_ct(:,1:k); t_ct = t(1:k); break;
    end

    q_dot_ct(:,k+1) = q_dot_now + Ts * q_ddot;
    q_ct(:,k+1) = q_now + Ts * q_dot_now;
    t_ct = t;
end
fprintf('CT done. Final error: %.4f\n', norm(q_d(:,min(k,N)) - q_ct(:,min(k,N))));

%% ===================== RUN 2: Robust =====================
fprintf('Running Robust...\n');
q_rb = zeros(4, N+1); q_dot_rb = zeros(4, N+1); tau_rb = zeros(4, N);
q_rb(:,1) = q0; q_dot_rb(:,1) = q_dot0;

for k = 1:N
    q_now = q_rb(:,k);
    q_dot_now = q_dot_rb(:,k);

    tau_rb(:,k) = robust_controller(q_now, q_dot_now, ...
                                    q_d(:,k), q_dot_d, q_ddot_d, ...
                                    Kp, Kv, p_nom, P, rho);

    M_plant = M_fun(q_now, p_true);
    C_plant = C_fun(q_now, q_dot_now, p_true);
    G_plant = G_fun(q_now, p_true);
    q_ddot = M_plant \ (tau_rb(:,k) - C_plant * q_dot_now - G_plant);

    if any(~isfinite(q_ddot))
        fprintf('ROBUST BLEW UP at k=%d, t=%.2f\n', k, t(k));
        q_rb = q_rb(:,1:k); q_dot_rb = q_dot_rb(:,1:k);
        tau_rb = tau_rb(:,1:k); t_rb = t(1:k); break;
    end

    q_dot_rb(:,k+1) = q_dot_now + Ts * q_ddot;
    q_rb(:,k+1) = q_now + Ts * q_dot_now;
    t_rb = t;
end
fprintf('Robust done. Final error: %.4f\n', norm(q_d(:,min(k,N)) - q_rb(:,min(k,N))));

%% ===================== RUN 3: Adaptive =====================
fprintf('Running Adaptive...\n');
q_ad = zeros(4, N+1); q_dot_ad = zeros(4, N+1); tau_ad = zeros(4, N);
q_ad(:,1) = q0; q_dot_ad(:,1) = q_dot0;
pi_hat_hist = zeros(n_params, N);
pi_hat = pi_hat_0;
pi_hat_hist(:,1) = pi_hat;

for k = 1:N
    q_now = q_ad(:,k);
    q_dot_now = q_dot_ad(:,k);

    [tau_ad(:,k), pi_hat, pi_hat_dot] = adaptive_controller( ...
        q_now, q_dot_now, ...
        q_d(:,k), q_dot_d, q_ddot_d, ...
        Kp, Kv, P, R_inv, ...
        pi_hat, p_geom, Ts);

    M_plant = M_fun(q_now, p_true);
    C_plant = C_fun(q_now, q_dot_now, p_true);
    G_plant = G_fun(q_now, p_true);
    q_ddot = M_plant \ (tau_ad(:,k) - C_plant * q_dot_now - G_plant);

    if any(~isfinite(q_ddot))
        fprintf('ADAPTIVE BLEW UP at k=%d, t=%.2f\n', k, t(k));
        q_ad = q_ad(:,1:k); q_dot_ad = q_dot_ad(:,1:k);
        tau_ad = tau_ad(:,1:k); pi_hat_hist = pi_hat_hist(:,1:k);
        t_ad = t(1:k); break;
    end

    q_dot_ad(:,k+1) = q_dot_now + Ts * q_ddot;
    q_ad(:,k+1) = q_now + Ts * q_dot_now;

    if k < N
        pi_hat_hist(:,k+1) = pi_hat;
    end
    t_ad = t;
end
fprintf('Adaptive done. Final error: %.4f\n', norm(q_d(:,min(k,N)) - q_ad(:,min(k,N))));

%% ===================== PLOTS =====================
fprintf('Generating plots...\n');
joint_labels = {'Joint 1', 'Joint 2', 'Joint 3', 'Joint 4'};

Nct = size(q_ct, 2) - 1;
Nrb = size(q_rb, 2) - 1;
Nad = size(q_ad, 2) - 1;

figure('Name', 'Trajectory: Joint Positions');
for i = 1:4
    subplot(2,2,i);
    plot(t, q_d(i,:), 'r--', 'LineWidth', 1.5); hold on;
    plot(t(1:Nct), q_ct(i,1:Nct), 'b', 'LineWidth', 1.2);
    plot(t(1:Nrb), q_rb(i,1:Nrb), 'g', 'LineWidth', 1.2);
    plot(t(1:Nad), q_ad(i,1:Nad), 'm', 'LineWidth', 1.2);
    xlabel('Time [s]'); ylabel('q_i [rad]');
    title(joint_labels{i}); grid on;
    if i == 1, legend('q_d', 'CT', 'Robust', 'Adaptive', 'Location', 'best'); end
end
sgtitle('Trajectory Tracking - Joint Positions');

figure('Name', 'Trajectory: Joint Velocities');
for i = 1:4
    subplot(2,2,i);
    plot(t(1:Nct), q_dot_ct(i,1:Nct), 'b', 'LineWidth', 1.2); hold on;
    plot(t(1:Nrb), q_dot_rb(i,1:Nrb), 'g', 'LineWidth', 1.2);
    plot(t(1:Nad), q_dot_ad(i,1:Nad), 'm', 'LineWidth', 1.2);
    xlabel('Time [s]'); ylabel('dq_i [rad/s]');
    title(joint_labels{i}); grid on;
    if i == 1, legend('CT', 'Robust', 'Adaptive', 'Location', 'best'); end
end
sgtitle('Trajectory Tracking - Joint Velocities');

figure('Name', 'Trajectory: Control Torques');
for i = 1:4
    subplot(2,2,i);
    plot(t(1:Nct), tau_ct(i,1:Nct), 'b', 'LineWidth', 1.2); hold on;
    plot(t(1:Nrb), tau_rb(i,1:Nrb), 'g', 'LineWidth', 1.2);
    plot(t(1:Nad), tau_ad(i,1:Nad), 'm', 'LineWidth', 1.2);
    xlabel('Time [s]'); ylabel('\tau_i [Nm]');
    title(joint_labels{i}); grid on;
    if i == 1, legend('CT', 'Robust', 'Adaptive', 'Location', 'best'); end
end
sgtitle('Trajectory Tracking - Control Torques');

e_ct = vecnorm(q_d(:,1:Nct) - q_ct(:,1:Nct));
e_rb = vecnorm(q_d(:,1:Nrb) - q_rb(:,1:Nrb));
e_ad = vecnorm(q_d(:,1:Nad) - q_ad(:,1:Nad));

figure('Name', 'Trajectory: Tracking Error Norm');
plot(t(1:Nct), e_ct, 'b', 'LineWidth', 1.5); hold on;
plot(t(1:Nrb), e_rb, 'g', 'LineWidth', 1.5);
plot(t(1:Nad), e_ad, 'm', 'LineWidth', 1.5);
xlabel('Time [s]'); ylabel('||e(t)||_2');
title('Trajectory Tracking - Error Norm');
legend('Computed Torque', 'Robust', 'Adaptive', 'Location', 'best');
grid on;

p_true_params = p_true(7:22);
param_names = {'m1','m2','m3','m4'};

figure('Name', 'Trajectory: Parameter Evolution');
for i = 1:4
    subplot(2,2,i);
    plot(t(1:size(pi_hat_hist,2)), pi_hat_hist(i,:), 'b', 'LineWidth', 1.2);
    hold on; yline(p_true_params(i), 'r--', 'LineWidth', 1.2);
    yline(pi_hat_0(i), 'k:', 'LineWidth', 1);
    xlabel('Time [s]'); ylabel(param_names{i});
    title(['Param: ' param_names{i}]); grid on;
    legend('Estimate', 'True', 'Initial', 'Location', 'best');
end
sgtitle('Trajectory Tracking - Parameter Evolution');

fprintf('Done! Trajectory tracking simulation complete.\n');